# =============================================================================
# 太陽能儲能監控系統 - 環境變數範例檔案
# Solar Energy Storage Management System - Environment Variables Example
# =============================================================================

# =========================================================================
# 資料庫配置 (PostgreSQL)
# =========================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=solar_storage
DB_USER=solar_admin
DB_PASSWORD=solar_secure_password_2024

# =========================================================================
# Redis 配置（用於即時數據緩存）
# =========================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =========================================================================
# JWT 認證配置
# =========================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# =========================================================================
# API 後端配置 (NestJS)
# =========================================================================
API_PORT=8000
NODE_ENV=production

# =========================================================================
# WebSocket 服務配置 (Socket.IO)
# =========================================================================
WS_PORT=8001

# =========================================================================
# 前端配置 (React + Vite)
# =========================================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001
